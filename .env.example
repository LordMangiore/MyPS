# Twilio Conversations
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_API_KEY_SID=SK...
TWILIO_API_KEY_SECRET=...
# Optional — defaults to the account's default Conversations service if unset
TWILIO_CONVERSATIONS_SERVICE_SID=IS...

# OTP / email
RESEND_API_KEY=re_...
RESEND_FROM="ProSource <onboarding@resend.dev>"
# Set to "true" to skip Resend in dev and accept any 6-digit code
OTP_DEV_BYPASS=false
